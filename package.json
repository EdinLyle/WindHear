{
  "name": "windhear",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,magenta \"vite\" \"tsx watch server/index.ts\"",
    "dev:web": "vite",
    "dev:api": "tsx watch server/index.ts",
    "build:web": "tsc -b && vite build",
    "build:api": "tsc -p server/tsconfig.json",
    "build": "npm run build:web && npm run build:api",
    "lint": "eslint .",
    "preview": "vite preview",
    "start:api": "node server-dist/index.js"
  },
  "dependencies": {
    "@types/multer": "^2.0.0",
    "cors": "^2.8.6",
    "driver.js": "^1.4.0",
    "express": "^5.2.1",
    "html-to-image": "^1.11.13",
    "multer": "^2.1.1",
    "pdfkit": "^0.18.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.7.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.1",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
